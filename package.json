    "lucide-react": "^0.562.0",
    "mammoth": "^1.11.0",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-zoom-pan-pinch": "^3.7.0",
